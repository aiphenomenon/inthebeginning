<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base application theme used by AndroidManifest.xml before Compose takes over.
        Uses Material3 DayNight theme so the splash screen has a dark background.
    -->
    <style name="Theme.InTheBeginning" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
</resources>
