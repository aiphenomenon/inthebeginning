{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist-browser",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src/constants.ts",
    "src/simulator.ts",
    "src/instruments.ts",
    "src/audio_engine.ts",
    "src/browser_main.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-browser"]
}
